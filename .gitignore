# =============================================
# MOI FASHION — .gitignore
# =============================================

# ─── Dependencies ────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output ────────────────────────────
dist/
dist-ssr/
build/

# ─── Environment & secrets ───────────────────
# ⚠️  NUNCA subir variables de entorno con API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Logs ────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editor / IDE ────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── OS generated ────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
ehthumbs.db

# ─── Vite ────────────────────────────────────
*.local
.vite/

# ─── TypeScript ──────────────────────────────
*.tsbuildinfo

# ─── Testing ─────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ─── Assets — LEER NOTA ABAJO ────────────────
#
# Los assets SÍ se incluyen en el repo.
# Para imágenes grandes (>500 KB) se recomienda Git LFS:
#
#   git lfs install
#   git lfs track "src/assets/images/**/*.png"
#   git lfs track "src/assets/images/**/*.jpg"
#   git lfs track "src/assets/images/**/*.webp"
#   git add .gitattributes
#
# Si en algún momento decides usar un CDN (Cloudinary, S3, etc.)
# y NO quieres subir las imágenes al repo, descomenta las líneas:
#
# src/assets/images/products/
# src/assets/images/carousel/
#
# El logo y los íconos SVG (<100 KB) siempre deben ir en el repo.
